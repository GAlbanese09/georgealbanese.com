---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-base-800 bg-base-950">
  <div class="mx-auto max-w-6xl px-6 py-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <div class="flex items-center gap-2">
        <span class="font-display text-sm text-base-400">
          &copy; {currentYear} George Albanese
        </span>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/george-albanese-45490087/"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs text-base-500 transition-colors hover:text-cyan-400"
        >
          LinkedIn
        </a>
        <span class="text-base-700">·</span>
        <a
          href="mailto:George.Albanese@outlook.com"
          class="font-mono text-xs text-base-500 transition-colors hover:text-cyan-400"
        >
          Email
        </a>
        <span class="text-base-700">·</span>
        <span class="font-mono text-xs text-base-600">
          Built with Astro + Cloudflare
        </span>
      </div>
    </div>
  </div>
</footer>
