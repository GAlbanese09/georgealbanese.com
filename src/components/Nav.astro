---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Resume', href: '/resume' },
  { label: 'Contact', href: '/#contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-base-800 bg-base-950/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo / Name -->
    <a href="/" class="group flex items-center gap-2">
      <span class="flex h-8 w-8 items-center justify-center rounded-md bg-cyan-500/10 border border-cyan-500/30 font-display text-sm font-bold text-cyan-400 transition-colors group-hover:bg-cyan-500/20">
        GA
      </span>
      <span class="hidden font-display text-sm font-medium text-base-200 sm:block">
        george<span class="text-cyan-400">albanese</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class:list={[
              'rounded-md px-3 py-1.5 font-mono text-xs tracking-wide transition-colors',
              isActive
                ? 'bg-cyan-500/10 text-cyan-400'
                : 'text-base-400 hover:text-base-200 hover:bg-base-800',
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="https://www.linkedin.com/in/george-albanese"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-2 rounded-md border border-base-700 px-3 py-1.5 font-mono text-xs tracking-wide text-base-400 transition-colors hover:border-cyan-700 hover:text-cyan-400"
      >
        LinkedIn ↗
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="flex items-center justify-center rounded-md p-2 text-base-400 transition-colors hover:bg-base-800 hover:text-base-200 md:hidden"
      aria-label="Toggle menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-base-800 bg-base-950/95 backdrop-blur-md md:hidden">
    <div class="flex flex-col px-6 py-4 gap-1">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href;
        return (
          <a
            href={link.href}
            class:list={[
              'rounded-md px-3 py-2.5 font-mono text-sm tracking-wide transition-colors',
              isActive
                ? 'bg-cyan-500/10 text-cyan-400'
                : 'text-base-400 hover:text-base-200 hover:bg-base-800',
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="https://www.linkedin.com/in/george-albanese"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 rounded-md border border-base-700 px-3 py-2.5 text-center font-mono text-sm tracking-wide text-base-400 transition-colors hover:border-cyan-700 hover:text-cyan-400"
      >
        LinkedIn ↗
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
