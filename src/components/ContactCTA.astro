---
---

<section id="contact" class="py-20 sm:py-28 border-t border-base-800 bg-base-900/40">
  <div class="mx-auto max-w-6xl px-6">
    <div class="fade-in text-center">
      <span class="terminal-label">// let's connect</span>
      <h2 class="mt-2 text-2xl font-bold text-base-50 sm:text-3xl">Get In Touch</h2>
      <p class="mt-4 mx-auto max-w-lg text-base-400">
        I'm open to endpoint engineering, cloud delivery, and IAM/security roles.
        Prefer remote. Happy to discuss how my experience fits your team.
      </p>
    </div>

    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      class="fade-in mt-10 mx-auto max-w-2xl space-y-5"
    >
      <input type="hidden" name="access_key" value="0dc0c185-6e64-434b-9ca9-8de7812fbd2c" />
      <input type="hidden" name="from_name" value="GeorgeAlbanese.com Contact Form" />
      <input type="hidden" name="redirect" value="https://georgealbanese.com/#contact" />
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

      <!-- Name & Email row -->
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="name" class="block font-mono text-xs text-base-400 mb-1.5">Name *</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            placeholder="Your name"
            class="w-full rounded-lg border border-base-700 bg-base-800 px-4 py-2.5 text-sm text-base-200 placeholder:text-base-600 transition-colors focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500/30"
          />
        </div>
        <div>
          <label for="email" class="block font-mono text-xs text-base-400 mb-1.5">Email *</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            placeholder="you@company.com"
            class="w-full rounded-lg border border-base-700 bg-base-800 px-4 py-2.5 text-sm text-base-200 placeholder:text-base-600 transition-colors focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500/30"
          />
        </div>
      </div>

      <!-- Subject -->
      <div>
        <label for="subject" class="block font-mono text-xs text-base-400 mb-1.5">Subject</label>
        <select
          name="subject"
          id="subject"
          class="w-full rounded-lg border border-base-700 bg-base-800 px-4 py-2.5 text-sm text-base-200 transition-colors focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500/30"
        >
          <option value="General Inquiry">General Inquiry</option>
          <option value="Job Opportunity">Job Opportunity</option>
          <option value="Collaboration">Collaboration</option>
        </select>
      </div>

      <!-- Message -->
      <div>
        <label for="message" class="block font-mono text-xs text-base-400 mb-1.5">Message *</label>
        <textarea
          name="message"
          id="message"
          required
          rows="5"
          placeholder="Tell me about the role or project..."
          class="w-full rounded-lg border border-base-700 bg-base-800 px-4 py-2.5 text-sm text-base-200 placeholder:text-base-600 transition-colors focus:border-cyan-500 focus:outline-none focus:ring-1 focus:ring-cyan-500/30 resize-y"
        ></textarea>
      </div>

      <!-- Submit -->
      <div class="text-center">
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-lg bg-cyan-500 px-8 py-3 font-mono text-sm font-medium text-base-950 transition-all hover:bg-cyan-400 hover:shadow-lg hover:shadow-cyan-500/20"
        >
          Send Message
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </div>
    </form>

    <div class="fade-in mt-8 flex items-center justify-center gap-4 text-base-500">
      <span class="font-mono text-xs">📍 Norwalk, CT</span>
      <span class="text-base-700">·</span>
      <span class="font-mono text-xs">🏠 Remote preferred</span>
      <span class="text-base-700">·</span>
      <span class="font-mono text-xs">📞 917-657-0636</span>
    </div>
  </div>
</section>
