---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog" description="Technical writing on endpoint management, identity governance, automation, and security.">
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <div class="fade-in">
        <span class="terminal-label">// blog & knowledge base</span>
        <h1 class="mt-2 text-3xl font-bold text-base-50 sm:text-4xl">Blog</h1>
        <p class="mt-3 mx-auto max-w-lg text-base-400">
          Technical writing on endpoint management, identity governance, automation patterns, and security architecture.
        </p>
      </div>

      <div class="fade-in mt-16 card p-8 max-w-md mx-auto">
        <div class="text-4xl mb-4">📝</div>
        <h2 class="font-display text-lg font-semibold text-base-200">Coming Soon</h2>
        <p class="mt-2 text-sm text-base-500">
          Articles on Conditional Access architecture, PowerShell automation patterns,
          identity lifecycle design, and more.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
