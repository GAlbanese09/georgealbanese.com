---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ data }) => !data.draft);
  return studies.map((study) => ({
    params: { slug: study.id.replace(/\.mdx?$/, '') },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const categoryColors: Record<string, string> = {
  identity: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
  endpoint: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
  security: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
  automation: 'text-cyan-300 bg-cyan-400/10 border-cyan-400/20',
};
---

<BaseLayout title={study.data.title} description={study.data.description}>
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="mx-auto max-w-4xl px-6">
      <!-- Back link -->
      <a
        href="/projects"
        class="fade-in inline-flex items-center gap-1 font-mono text-xs text-base-400 transition-colors hover:text-cyan-400"
      >
        ← Back to Projects
      </a>

      <!-- Header -->
      <div class="fade-in mt-8">
        <div class="flex items-center gap-3">
          {study.data.icon && <span class="text-3xl">{study.data.icon}</span>}
          <div>
            <h1 class="text-3xl font-bold text-base-50 sm:text-4xl">{study.data.title}</h1>
            <span class={`inline-block mt-2 rounded-full px-2.5 py-0.5 font-mono text-[0.6rem] uppercase tracking-wider border ${categoryColors[study.data.category]}`}>
              {study.data.category}
            </span>
          </div>
        </div>
        <p class="mt-4 text-base-400 leading-relaxed">{study.data.description}</p>
      </div>

      <!-- Tags -->
      <div class="fade-in mt-6 flex flex-wrap gap-1.5">
        {study.data.tags.map((tag: string) => (
          <span class="badge text-[0.6rem]">{tag}</span>
        ))}
      </div>

      <!-- Metrics -->
      {study.data.metrics && study.data.metrics.length > 0 && (
        <div class="fade-in mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {study.data.metrics.map((metric: { label: string; value: string }) => (
            <div class="card p-4 text-center">
              <div class="font-display text-xl font-bold text-cyan-400">{metric.value}</div>
              <div class="mt-1 font-mono text-[0.6rem] text-base-500 uppercase tracking-wide">{metric.label}</div>
            </div>
          ))}
        </div>
      )}

      <!-- MDX Content -->
      <div class="fade-in mt-12 prose-custom">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .prose-custom h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-base-50);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-base-800);
  }
  .prose-custom h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-base-100);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-custom p {
    color: var(--color-base-300);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-custom strong {
    color: var(--color-base-100);
    font-weight: 600;
  }
  .prose-custom a {
    color: var(--color-cyan-400);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }
  .prose-custom a:hover {
    color: var(--color-cyan-300);
  }
  .prose-custom ul,
  .prose-custom ol {
    color: var(--color-base-300);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-custom li {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }
  .prose-custom ul {
    list-style-type: disc;
  }
  .prose-custom ol {
    list-style-type: decimal;
  }
  .prose-custom table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .prose-custom th {
    text-align: left;
    padding: 0.625rem 1rem;
    border-bottom: 2px solid var(--color-base-700);
    color: var(--color-base-200);
    font-weight: 600;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .prose-custom td {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-base-800);
    color: var(--color-base-300);
  }
  .prose-custom tr:last-child td {
    border-bottom: none;
  }
  .prose-custom code {
    background: var(--color-base-800);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.85em;
    color: var(--color-cyan-400);
  }
  .prose-custom pre {
    background: var(--color-base-800);
    border: 1px solid var(--color-base-700);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose-custom pre code {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: 0.85em;
    color: var(--color-base-200);
  }
  .prose-custom hr {
    border: none;
    border-top: 1px solid var(--color-base-800);
    margin: 2rem 0;
  }
  .prose-custom blockquote {
    border-left: 3px solid var(--color-cyan-500);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--color-base-400);
    font-style: italic;
  }
</style>
