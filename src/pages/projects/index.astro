---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Phase 2: These will come from the content collection
// import { getCollection } from 'astro:content';
// const caseStudies = (await getCollection('case-studies'))
//   .filter(study => !study.data.draft)
//   .sort((a, b) => a.data.order - b.data.order);

// For now, static data matching what will become MDX case studies
const projects = [
  {
    title: 'Conditional Access Architecture',
    description: 'Designed 20 policies from scratch — per-platform compliance enforcement, tiered MFA, risk-based policies, legacy auth blocking, BYOD containment, and Cloud PC controls.',
    tags: ['Entra ID', 'Conditional Access', 'Zero Trust', 'MFA'],
    metrics: [
      { label: 'Policies Built', value: '20' },
      { label: 'Platforms', value: '6' },
    ],
    category: 'identity',
    icon: '🔐',
    slug: 'conditional-access-architecture',
    comingSoon: true,
  },
  {
    title: 'Identity Lifecycle Automation',
    description: 'HR-driven provisioning pipeline and Jira-triggered termination automation with idempotency, retry/backoff, kill switches, and certificate-based Graph API auth.',
    tags: ['PowerShell', 'Graph API', 'Azure Automation', 'Dayforce'],
    metrics: [
      { label: 'Onboard Savings', value: '~15 min' },
      { label: 'Offboard Savings', value: '~10 min' },
    ],
    category: 'automation',
    icon: '⚡',
    slug: 'identity-lifecycle-automation',
    comingSoon: true,
  },
  {
    title: 'Endpoint Compliance at Scale',
    description: '585-device fleet across Intune and Jamf with 80 config profiles, 7 compliance policies, staged Autopatch rings, and cross-platform security baselines.',
    tags: ['Intune', 'Jamf Pro', 'Autopatch', 'Compliance'],
    metrics: [
      { label: 'Devices', value: '585+' },
      { label: 'Config Profiles', value: '80' },
    ],
    category: 'endpoint',
    icon: '💻',
    slug: 'endpoint-compliance-at-scale',
    comingSoon: true,
  },
  {
    title: 'Endpoint Security Stack',
    description: 'Full security implementation: ASR rules, BitLocker silent deployment, Defender for Endpoint/EDR across Windows and macOS, LAPS with version-aware pilots.',
    tags: ['ASR Rules', 'BitLocker', 'Defender EDR', 'LAPS'],
    metrics: [
      { label: 'ASR Rules', value: '5+' },
      { label: 'Fleet Coverage', value: '100%' },
    ],
    category: 'security',
    icon: '🛡️',
    slug: 'endpoint-security-stack',
    comingSoon: true,
  },
  {
    title: 'CVE Intake Automation',
    description: 'Teams-triggered automation that pulls Defender TVM API data and creates enriched Jira tickets, standardizing vulnerability triage across the organization.',
    tags: ['Defender TVM', 'PowerShell', 'Jira', 'Teams'],
    metrics: [
      { label: 'Manual Steps Removed', value: 'All' },
      { label: 'Triage Time', value: 'Minutes' },
    ],
    category: 'automation',
    icon: '🔍',
    slug: 'cve-intake-automation',
    comingSoon: true,
  },
];

const categoryColors: Record<string, string> = {
  identity: 'text-amber-400 bg-amber-500/10 border-amber-500/20',
  endpoint: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
  security: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
  automation: 'text-cyan-300 bg-cyan-400/10 border-cyan-400/20',
};
---

<BaseLayout title="Projects" description="Case studies showcasing endpoint management, identity governance, security, and automation work.">
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="mx-auto max-w-6xl px-6">
      <!-- Header -->
      <div class="fade-in">
        <span class="terminal-label">// case studies</span>
        <h1 class="mt-2 text-3xl font-bold text-base-50 sm:text-4xl">Projects</h1>
        <p class="mt-3 max-w-2xl text-base-400">
          Sanitized case studies from production environments. Each covers the problem,
          architecture decisions, implementation, and measurable outcomes.
        </p>
      </div>

      <!-- Project Cards Grid -->
      <div class="mt-10 grid gap-5 sm:grid-cols-2">
        {projects.map((project, i) => (
          <div class="fade-in card p-6 flex flex-col" style={`animation-delay: ${i * 0.05}s`}>
            {/* Header */}
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <span class="text-2xl">{project.icon}</span>
                <div>
                  <h2 class="font-display text-base font-semibold text-base-50">{project.title}</h2>
                  <span class={`inline-block mt-1 rounded-full px-2 py-0.5 font-mono text-[0.55rem] uppercase tracking-wider border ${categoryColors[project.category]}`}>
                    {project.category}
                  </span>
                </div>
              </div>
            </div>

            {/* Description */}
            <p class="mt-4 text-sm text-base-400 leading-relaxed flex-1">
              {project.description}
            </p>

            {/* Metrics */}
            <div class="mt-4 flex gap-4">
              {project.metrics.map((metric) => (
                <div>
                  <div class="font-display text-lg font-bold text-cyan-400">{metric.value}</div>
                  <div class="font-mono text-[0.55rem] text-base-500 uppercase tracking-wide">{metric.label}</div>
                </div>
              ))}
            </div>

            {/* Tags */}
            <div class="mt-4 flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="badge text-[0.6rem]">{tag}</span>
              ))}
            </div>

            {/* Coming Soon / Link */}
            {project.comingSoon ? (
              <div class="mt-4 pt-4 border-t border-base-700">
                <span class="font-mono text-xs text-base-600">Full case study coming soon</span>
              </div>
            ) : (
              <a
                href={`/projects/${project.slug}`}
                class="mt-4 pt-4 border-t border-base-700 font-mono text-xs text-cyan-400 hover:text-cyan-300 transition-colors inline-flex items-center gap-1"
              >
                Read case study →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
