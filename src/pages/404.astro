---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <section class="pt-32 pb-20 sm:pt-40 sm:pb-28">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <div class="font-display text-8xl font-bold text-base-800">404</div>
      <h1 class="mt-4 text-2xl font-bold text-base-50">Page Not Found</h1>
      <p class="mt-3 text-base-400">
        This endpoint doesn't exist. Let's get you back on track.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-cyan-500 px-5 py-2.5 font-mono text-sm font-medium text-base-950 transition-all hover:bg-cyan-400"
      >
        ← Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
